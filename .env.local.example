# ─── Database (Neon Postgres via Vercel) ─────────────────────────────────────
# Pooled connection (used by Prisma at runtime via pgBouncer)
DATABASE_URL="your-neon-pooled-connection-string"
# Direct connection (used by Prisma for migrations/db push)
DATABASE_URL_UNPOOLED="your-neon-direct-connection-string"

# ─── Email (Resend) ──────────────────────────────────────────────────────────
# Get your API key at https://resend.com — free tier is enough to start
RESEND_API_KEY="re_your_api_key_here"

# Joseph's email — receives order notifications and contact form submissions
JOSEPH_EMAIL="joseph@pureowater.com"

# ─── Site URL ────────────────────────────────────────────────────────────────
# No trailing slash
NEXT_PUBLIC_SITE_URL="https://pureowater.com"

# ─── Admin Login ─────────────────────────────────────────────────────────────
# Change both of these before deploying to production
ADMIN_USERNAME="joseph"
ADMIN_PASSWORD="choose-a-strong-password-here"

# ─── Session Secret ──────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Must be at least 32 characters. Keep this secret.
SESSION_SECRET="replace-this-with-a-random-64-character-string"

# ─── Google Analytics 4 ──────────────────────────────────────────────────────
NEXT_PUBLIC_GA_ID=G-860S27DESN
